# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---- OpenAI (MVP provider) ----
OPENAI_API_KEY=

# ---- AWS Transcribe (post-MVP) ----
# For local development, use an IAM user with a named profile (see docs/AWS_TRANSCRIBE_SETUP.md).
# On EC2, omit AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY entirely and attach an IAM role instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-1
AWS_TRANSCRIBE_BUCKET=
AWS_PROFILE=                          # Named local profile (local dev only; omit on EC2)
AWS_TRANSCRIBE_CLEANUP_S3=true        # Delete S3 input/output objects after saving locally
AWS_TRANSCRIBE_POLL_SECONDS=5         # How often to poll async Transcribe job status
AWS_TRANSCRIBE_MAX_WAIT_SECONDS=1800  # Give up after 30 minutes

# ---- Other providers (placeholders for the future roadmap) ----
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=

# ---- App configuration ----
TRANSCRIPT_WORKBENCH_DATA_DIR=./data
MAX_UPLOAD_MB=200
LOW_CONFIDENCE_THRESHOLD=0.80
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini-transcribe

# ---- Email sharing ----
# Email sharing turns on when EMAIL_SENDER and EMAIL_RECIPIENTS are set (and,
# for smtp, the SMTP credentials below). Setup guide: docs/EMAIL_SETUP.md
EMAIL_PROVIDER=smtp            # "smtp" (Gmail app password) or "ses" (AWS SES)
EMAIL_SENDER=                  # From address (smtp: your Gmail or a "Send mail as" alias; ses: a verified identity)
EMAIL_RECIPIENTS=              # Comma-separated allowlist shown in the UI
EMAIL_MAX_ATTACHMENT_MB=25     # Gmail and SES both reject larger messages
EMAIL_DAILY_LIMIT=20           # Max successful sends per UTC day (abuse backstop)

# SMTP credentials (only used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=                 # Your full Gmail address
SMTP_PASSWORD=                 # A 16-character Google app password, NOT your real password
